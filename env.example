# App Configuration (optional)
# The app URL is automatically detected. Override only if needed for local development.
# VITE_APP_URL=http://localhost:3000

# Note: No API keys or secrets are needed!
# The Spotify Client ID is entered directly in the app on the "Setup" page
# and is stored locally in the browser (localStorage).
# Authentication uses OAuth 2.0 with PKCE – no client secret required.
#
# IMPORTANT: You need a Spotify Premium account to create a
# Spotify Developer account and use the Web API.
